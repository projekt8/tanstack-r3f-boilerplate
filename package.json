{
  "name": "tanstack-r3f-boilerplate",
  "version": "1.0.0",
  "homepage": "https://projekt8.github.io/tanstack-r3f-boilerplate",
  "description": "A modern, high-performance boilerplate built for the next generation of web experiences. Combining the power of TanStack Start for full-stack capabilities, React Three Fiber for immersive 3D content, and GSAP for award-winning animations.",
  "keywords": [
    "tanstack",
    "react-three-fiber",
    "gsap",
    "lenis",
    "tempus",
    "react",
    "tailwindcss",
    "typescript",
    "vite"
  ],
  "author": {
    "name": "Kerim Hadri",
    "homepage": "https://projekt8.net"
  },
  "engines": {
    "node": "v25.9.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier",
    "format:fix": "prettier --write .",
    "check": "npm run lint:fix && npm run format:fix",
    "optimize:models": "tsx scripts/optimize-models/index.ts"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router": "1.168.24",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.48",
    "@tanstack/router-plugin": "1.167.26",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "gsap": "3.15.0",
    "lenis": "1.3.23",
    "lucide-react": "1.11.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "tempus": "1.0.0-dev.17",
    "three": "0.184.0",
    "vite-tsconfig-paths": "6.1.1",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/playfair-display": "5.2.8",
    "@pmndrs/assets": "1.7.0",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "commander": "14.0.3",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "ts-morph": "28.0.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-glsl": "1.6.0",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.5"
  }
}
